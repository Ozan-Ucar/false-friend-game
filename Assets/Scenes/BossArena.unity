--- !u!114 &591137308
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 591137307}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 42d80de5cb1ffc64cbff38f59ab280f7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogTrigger
  dialogLines:
  - speakerName: Anni
    text: "Du bist also hier der K\xF6nig dieser Welt."
    additionalTexts:
    - Hallo...? Hast du meinen Kappa gesehen?
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: ???
    text: Du hast den Palast erreicht.
    additionalTexts: []
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Wo ist mein Kappa?
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: ???
    text: Die ganze Zeit so nah... und du hast es nicht gemerkt.
    additionalTexts:
    - 
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Was meinst du?
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: Ich war nie weg, Anni.
    additionalTexts: []
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 2
  - speakerName: Anni
    text: ...Kappa?
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: "Du hast jedes Spiel gespielt. Jede Falle \xFCberlebt. Genau wie ich es
      wollte."
    additionalTexts: []
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Warum hast du das gemacht?
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: "Weil deine Welt mein K\xE4fig war."
    additionalTexts:
    - "Und du warst der Schl\xFCssel."
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Ich habe dich gesucht...
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: "Genau. Deshalb hast du jede T\xFCr ge\xF6ffnet."
    additionalTexts: []
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Du hast mich benutzt?
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: Du hast mich befreit.
    additionalTexts: []
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Anni
    text: Nein... du warst mein Freund.
    additionalTexts: []
    speakerSprite: {fileID: -7231753499768611675, guid: 0415d3f8758de1244a4994a53fb49c54, type: 3}
    side: 0
    portraitScale: 0.6
  - speakerName: Kappa
    text: 'Ich war dein Haustier. '
    additionalTexts:
    - 
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 1.6
  - speakerName: Kappa
    text: Ein letztes Spiel, Anni.
    additionalTexts:
    - 
    speakerSprite: {fileID: -8149934360737518084, guid: 55c4f1497cdac8849ad8898e3c257762, type: 3}
    side: 1
    portraitScale: 2.5
  playOnce: 1
  saveProgress: 0
  uniqueID: 
  onDialogFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 1598601893}
        m_TargetAssemblyTypeName: BossCannonFightManager, Assembly-CSharp
        m_MethodName: BeginBossFight
        m_Mode: 1
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 0
        m_CallState: 2
